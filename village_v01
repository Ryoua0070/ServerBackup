function isValidVillageName(name) {

    if (!name) return false;

    name = name.trim();

    if (name.length < 2) return false;

    if (name.length > 12) return false;

    const regex =
        /^[가-힣a-zA-Z0-9]+$/;

    return regex.test(name);

}

function villageExists(name) {

    name = name.trim();

    for (const id in villageManager.data.villages) {

        const village =
            villageManager.data.villages[id];

        if (
            village.name === name
        ) {

            return true;

        }

    }

    return false;

}


