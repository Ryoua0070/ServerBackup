world.afterEvents.itemUse.subscribe(async (event) => {

    const player = event.source;

    if (event.itemStack.typeId !== "minecraft:gold_nugget") return;

    const menu = new ActionFormData()
        .title("메인 메뉴")
        .body("테스트 메뉴");

    menu.button("탭 1");
    menu.button("탭 2");
    menu.button("탭 3");
    menu.button("🏠 마을");

    const result = await menu.show(player);

    if (result.canceled) return;

    switch (result.selection) {

        case 0:
            player.sendMessage("탭1");
            break;

        case 1:
            player.sendMessage("탭2");
            break;

        case 2:
            player.sendMessage("탭3");
            break;

        case 3:
            showVillageMenu(player);
            break;
    }

});

async function showVillageMenu(player) {

    const hasVillage = villageManager.has(player);

    const form = new ActionFormData()
        .title("🏠 마을")
        .body("마을 메뉴");

    const buttons = [];

    if (!hasVillage) {

        form.button("🏗 마을 생성");
        buttons.push("create");

    } else {

        form.button("🚪 마을 이동");
        buttons.push("move");

        form.button("📜 마을 정보");
        buttons.push("info");

        form.button("❌ 마을 탈퇴");
        buttons.push("leave");

    }

    form.button("⬅ 뒤로");
    buttons.push("back");

    const result = await form.show(player);

    if (result.canceled) return;

    switch (buttons[result.selection]) {

        case "create":
            villageManager.showCreateForm(player);
            break;

        case "move":
            villageManager.teleport(player);
            break;

        case "info":
            villageManager.showInfo(player);
            break;

        case "leave":
            villageManager.leave(player);
            break;

        case "back":
            return;
    }

}






