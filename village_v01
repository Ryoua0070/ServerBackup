/* ===========================
   마을 경계
=========================== */

system.runInterval(() => {

    if (!villageManager) return;

    for (const player of world.getPlayers()) {

        const village =
            villageManager.get(player);

        if (!village) continue;

        if (
            player.dimension.id !==
            VILLAGE_DIMENSION
        ) continue;

        const dx =
            player.location.x -
            village.center.x;

        const dz =
            player.location.z -
            village.center.z;

        const distance =
            dx * dx +
            dz * dz;

        if (
            distance >
            VILLAGE_RADIUS *
            VILLAGE_RADIUS
        ) {

            player.teleport(
                village.center,
                {
                    dimension:
                        player.dimension
                }
            );

            player.sendMessage(
                "§c마을 밖으로 나갈 수 없습니다."
            );

        }

    }

}, 20);

